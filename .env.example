# Gateway (set on the laptop hosting the gateway)
CC_PROVIDER_API_KEY=replace-with-a-long-provider-secret
CC_CLIENT_API_KEY=replace-with-a-long-client-secret

# Provider node (set on the laptop hosting the provider node)
# CC_PROVIDER_API_KEY must match the gateway's provider key.
CC_GATEWAY_URL=http://GATEWAY_LAN_IP:8000
CC_NODE_ID=laptop-provider-1
# This URL must be reachable by the gateway laptop.
CC_NODE_ENDPOINT_URL=http://PROVIDER_LAN_IP:8001
CC_NODE_GPU_NAME=Example GPU
CC_NODE_VRAM_GB=8
CC_NODE_MAX_GPU_USAGE_PERCENT=50
CC_NODE_AVAILABILITY=always
CC_HEARTBEAT_INTERVAL_SECONDS=15
